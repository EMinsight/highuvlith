# config to something non-ambiguous (e.g. app.config.json) rather than
# loosening this rule.
config.json

# ============================================================
# Version control scratch
# ============================================================

# Backup / merge / patch leftovers
*.bak
*.backup
*.tmp
*.temp
*.orig
*.rej
*.local

# Patches & diffs
*.patch
*.diff

# Git-rewrite staging area (produced by `git filter-repo` etc.)
.git-rewrite/

# Legacy VCS directories (guard against accidental imports)
.svn/
.hg/
CVS/

