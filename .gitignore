# ============================================================

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.gcda
*.gcno
*.profraw
*.profdata

# Cargo fuzz corpus and artifacts
/fuzz/artifacts/
/fuzz/corpus/

# Criterion benchmark output
/target/criterion/

