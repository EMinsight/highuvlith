# ============================================================
# Rust
# ============================================================

# Cargo build output (debug, release, bench, all targets)
/target/

# Intermediate compiler artifacts
*.rlib
*.rmeta

# ============================================================
# Python
# ============================================================

# Virtual environments (any naming convention)
/.venv/
/venv/
/.env/
/env/
.python-version

# Bytecode & caches
__pycache__/
*.py[cod]
*$py.class

# Packaging artifacts
*.egg-info/
*.egg
/dist/
/build/
/wheels/
*.whl
/sdist/

# ============================================================
# Compiled extensions (maturin develop / pip install -e)
# ============================================================

*.so
*.dylib
*.dll
*.pyd
*.dSYM/

# ============================================================
# Generated / large binary outputs
# ============================================================

# Demo videos produced by examples/generate_demo.py
examples/*.mp4
examples/*.webm
examples/*.avi
examples/*.mkv
examples/*.gif

# Exported simulation images
*.exr

