# ============================================================
# Rust
# ============================================================

# Cargo build output (debug, release, bench, all targets)
/target/

# Intermediate compiler artifacts
*.rlib
*.rmeta

# Rust temporary files
rustc-ice-*.txt

# Cargo-generated lockfiles in libraries (keep in binaries)
# Cargo.lock  # Already committed, so commenting this pattern

