# ============================================================

# Trunk bundler output
/crates/highuvlith-gui/dist/
/web/dist/
/web/pkg/
# wasm-pack output
/pkg/
# Node.js (only relevant if a web frontend is added later)
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

