# ============================================================
# Rust / Cargo
# ============================================================

# Workspace build output (all profiles, all targets)
/target/
# Additional target dirs from cross-compilation or `cargo --target-dir`
/target-*/
**/target/

# Criterion benchmark output (covered by /target/ but explicit for clarity)
/target/criterion/

# Intermediate compiler artifacts
*.rlib
*.rmeta
# Windows debug symbols
*.pdb

# Internal compiler error dumps
rustc-ice-*.txt

# rustfmt backup files
*.rs.bk

# Cargo-fuzz corpora
/fuzz/artifacts/
/fuzz/corpus/

# Coverage (llvm-cov / grcov)
*.profraw
*.profdata
*.gcda
*.gcno

# Cargo.lock is intentionally committed for this workspace (binaries publish
# with it). Do not add it here.

# ============================================================
# Python
# ============================================================

# Virtual environments (any common naming convention)
/.venv/
/venv/
/.env/
/env/
/site-packages/
.python-version
.Python

# Bytecode & caches
__pycache__/
*.py[cod]
*$py.class

# Packaging / build artifacts
*.egg
*.egg-info/
.eggs/
/build/
/dist/
/sdist/
/wheels/
*.whl
pip-log.txt
pip-delete-this-directory.txt
pip-wheel-metadata/
MANIFEST
.installed.cfg

# PDM / Poetry / Hatch lockfile-adjacent caches (Cargo.lock is committed;
# Python lockfiles are tool-specific and not used in this repo yet)
__pypackages__/
.pdm-python
.pdm-build/
.hatch/

# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py
.jupyter/

# Scientific / numerical scratch data
*.npy
*.npz
*.h5
*.hdf5
*.pkl
*.pickle
*.joblib

# ============================================================
# PyO3 / maturin native extension
# ============================================================

# Compiled extension modules produced by `maturin develop`
*.so
*.dylib
*.dll
*.pyd
*.dSYM/

# Maturin build cache (extra — main target dir already covered above)
.maturin-cache/

