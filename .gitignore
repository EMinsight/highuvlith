# Profiling
# ============================================================

# Flamegraph / perf
flamegraph.svg
perf.data
perf.data.old

# Valgrind
callgrind.out.*
cachegrind.out.*
massif.out.*

# dhat (heap profiler)
dhat-*.json

# samply, pprof, generic profiling dumps
samply.json*
*.prof

# Heaptrack
*.heaptrack

# ============================================================
# Generated assets (CLI image output, demo videos)
# ============================================================

# Demo videos produced by examples/generate_demo.py
examples/*.mp4
examples/*.webm
examples/*.avi
examples/*.mkv
examples/*.gif

# OpenEXR exports (the CLI can also emit PNG/TIFF; those paths are user-chosen
# so we do not blanket-ignore those extensions — add project outputs explicitly
# below if a known output dir is introduced)
*.exr

